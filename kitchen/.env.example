PORT=3002
DATABASE_URL=postgresql://localhost:5432/kitchen_db

# Required on VPS (generate: openssl rand -hex 32)
SESSION_SECRET=change-me-long-random-string

# Cookie path must be "/" — nginx serves /kitchen/* but proxies /api/* to this app
COOKIE_PATH=/

# Session expires after 10 minutes of inactivity (milliseconds)
SESSION_MAX_AGE_MS=600000

# Set true only when users access kitchen over HTTPS (not http://host:8088)
# COOKIE_SECURE=false

# Or use individual vars:
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=yourpassword
# PG_DATABASE=kitchen_db
